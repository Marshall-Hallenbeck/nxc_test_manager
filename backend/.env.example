DATABASE_URL=postgresql://postgres:postgres@localhost:5438/netexec_tests
REDIS_URL=redis://localhost:6381/0

# Required — GitHub API token (create at https://github.com/settings/tokens)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Default test targets (single IP, comma-separated IPs, subnet, or mixed)
DEFAULT_TARGET_HOSTS=192.168.56.10
# Examples (GOAD IPs)
# DEFAULT_TARGET_HOSTS=192.168.56.10,192.168.56.22
# DEFAULT_TARGET_HOSTS=192.168.56.0/24
# DEFAULT_TARGET_HOSTS=192.168.56.0/24,192.168.33.10
DEFAULT_TARGET_USERNAME=Administrator
DEFAULT_TARGET_PASSWORD=Passw0rd!

# Email notifications (optional, disabled by default)
EMAIL_ENABLED=false
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=netexec-tests@example.com
SMTP_TO=admin@example.com

# Empire C2 (for empire_exec e2e tests, auto-initialized on worker start)
EMPIRE_HOST=127.0.0.1
EMPIRE_PORT=1337
EMPIRE_USERNAME=empireadmin
EMPIRE_PASSWORD=password123

# Default repository (owner/name format, for testing forks)
DEFAULT_REPO=Pennyw0rth/NetExec

# Container settings
CONTAINER_TIMEOUT=1800
CONTAINER_MEMORY_LIMIT=2g
CELERY_WORKERS=3

# GitHub Webhooks (optional, disabled by default)
WEBHOOK_ENABLED=false
WEBHOOK_SECRET=your-webhook-secret-here
WEBHOOK_AUTO_TEST_EVENTS=opened,synchronize
WEBHOOK_REPO_FILTER=Pennyw0rth/NetExec
